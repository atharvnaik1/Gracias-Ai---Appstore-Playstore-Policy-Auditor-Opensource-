json
{
  "version": 2,
  "name": "atharvnaik1s-projects",
  "teamId": "team_c0hqDrZckNBm5AkYTYHVKoE8",
  "build": {
    "src": "next.config.mjs",
    "use": "@vercel/next"
  },
  "outputDirectory": "out",
  "functions": {
    "api/**/*.js": {
      "runtime": "nodejs18.x"
    },
    "app/api/**/*.js": {
      "runtime": "nodejs18.x"
    }
  },
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "env": {
    "MONGODB_URI": "mongodb+srv://<username>:<password>@cluster0.mongodb.net/<dbname>?retryWrites=true&w=majority",
    "MONGODB_DB": "mydatabase"
  }
}