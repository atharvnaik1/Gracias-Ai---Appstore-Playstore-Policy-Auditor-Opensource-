json
{
  "version": 2,
  "name": "atharvnaik1s-projects",
  "teamId": "team_c0hqDrZckNBm5AkYTYHVKoE8",
  "build": {
    "src": "next.config.js",
    "use": "@vercel/next",
    "buildCommand": "npm run build"
  },
  "outputDirectory": ".out",
  "functions": {
    "api/**/*.js": {
      "runtime": "nodejs18.x"
    },
    "app/api/**/*.js": {
      "runtime": "nodejs18.x"
    }
  },
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/_next/static/(.*)",
      "dest": "/_next/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "env": {
    "MONGODB_URI": "mongodb+srv://<username>:<password>@cluster0.mongodb.net/<dbname>?retryWrites=true&w=majority",
    "OPENAI_API_KEY": "<your-openai-key>",
    "ANTHROPIC_API_KEY": "<your-anthropic-key>"
  }
}