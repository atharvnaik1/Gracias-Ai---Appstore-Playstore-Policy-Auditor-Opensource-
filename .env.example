# Example environment variables for deployment
# Copy this file to .env and replace placeholder values with your actual credentials

# Application settings
PORT=3000
NODE_ENV=production
APP_URL=https://your-domain.com

# Database
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/<dbname>?retryWrites=true&w=majority

# Cache / Session store (optional)
# REDIS_URL=redis://<username>:<password>@redis-host:6379/0

# OpenAI API
OPENAI_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Optional third‑party services
# GOOGLE_MAPS_API_KEY=AIzaSyXXXXXXX-XXXXXXXXXXXXXX
# SENDGRID_API_KEY=SG.XXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Security / Secrets
JWT_SECRET=your_jwt_secret_key
SESSION_SECRET=your_session_secret_key

# Logging / Monitoring
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# LOG_LEVEL=info

# Feature flags (example)
# ENABLE_FEATURE_X=true
# ENABLE_FEATURE_Y=false

# Add any additional environment variables required by your application below.