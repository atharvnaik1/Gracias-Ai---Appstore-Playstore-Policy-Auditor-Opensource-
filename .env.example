# .env.example - Example environment configuration for Vercel deployment
# Copy this file to .env and replace placeholder values with your actual credentials.

# Database
MONGODB_URI=<YOUR_MONGODB_CONNECTION_STRING>

# OpenAI
OPENAI_API_KEY=<YOUR_OPENAI_API_KEY>

# Anthropic
ANTHROPIC_API_KEY=<YOUR_ANTHROPIC_API_KEY>

# Authentication (NextAuth.js)
NEXTAUTH_URL=https://<YOUR_PROJECT>.vercel.app
NEXTAUTH_SECRET=<YOUR_RANDOM_SECRET>

# Vercel deployment
VERCEL_PROJECT_ID=<YOUR_VERCEL_PROJECT_ID>
VERCEL_ORG_ID=<YOUR_VERCEL_ORG_ID>
VERCEL_ENV=production

# Optional third‑party services
# Stripe
STRIPE_SECRET_KEY=<YOUR_STRIPE_SECRET_KEY>
STRIPE_WEBHOOK_SECRET=<YOUR_STRIPE_WEBHOOK_SECRET>

# SendGrid (email)
SENDGRID_API_KEY=<YOUR_SENDGRID_API_KEY>
EMAIL_FROM=<YOUR_EMAIL_ADDRESS>

# Google OAuth (if used)
GOOGLE_CLIENT_ID=<YOUR_GOOGLE_CLIENT_ID>
GOOGLE_CLIENT_SECRET=<YOUR_GOOGLE_CLIENT_SECRET>

# GitHub OAuth (if used)
GITHUB_CLIENT_ID=<YOUR_GITHUB_CLIENT_ID>
GITHUB_CLIENT_SECRET=<YOUR_GITHUB_CLIENT_SECRET>

# Miscellaneous
LOG_LEVEL=info
PORT=3000

# End of file.