# Required Environment Variables
# Copy this file to .env.local and fill in the values

# MongoDB - Required for saving audit reports
MONGODB_URI=mongodb://localhost:27017/ipaship

# Clerk Authentication - Required for user authentication
# Get your keys from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: AI Provider API Keys
# At least one provider key is needed for audits
# Anthropic
ANTHROPIC_API_KEY=
# OpenAI
OPENAI_API_KEY=
# Google AI (Gemini)
GEMINI_API_KEY=
# OpenRouter
OPENROUTER_API_KEY=
