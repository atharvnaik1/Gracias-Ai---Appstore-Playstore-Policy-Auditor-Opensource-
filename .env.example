# .env.example – Example environment variables for the Gracias AI AppStore Policy Auditor

# MongoDB connection string
# Format: mongodb+srv://<username>:<password>@<cluster>/<dbname>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/<dbname>?retryWrites=true&w=majority

# Anthropic Claude API key (used for AI processing)
CLAUDE_API_KEY=your_claude_api_key

# NVIDIA API key (for GPU‑accelerated inference)
NVIDIA_API_KEY=your_nvidia_api_key

# Vercel deployment URL (automatically set by Vercel in production)
VERCEL_URL=https://your-app.vercel.app

# Application port (default for Vercel is 3000)
PORT=3000

# Node environment (development, production, test)
NODE_ENV=production

# Secret for signing JWT tokens or session cookies
JWT_SECRET=your_jwt_secret_here

# Log level (error, warn, info, debug)
LOG_LEVEL=info

# Optional: OpenAI API key if the project also uses OpenAI services
OPENAI_API_KEY=your_openai_api_key

# Optional: Redis URL for caching or rate limiting
REDIS_URL=redis://<username>:<password>@<host>:<port>

# Optional: Sentry DSN for error monitoring
SENTRY_DSN=your_sentry_dsn

# Optional: Email service configuration (e.g., SendGrid)
SENDGRID_API_KEY=your_sendgrid_api_key
EMAIL_FROM=no-reply@yourdomain.com

# Optional: Feature flags (comma‑separated list)
FEATURE_FLAGS=feature_a,feature_b

# End of .env.example

