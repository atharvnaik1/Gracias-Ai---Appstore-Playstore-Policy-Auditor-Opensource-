\r\t\v\f") or " " in stripped:
        raise InvalidKeyFormatError(
            f"Invalid characters in {name}. API keys must be a single line "
            "without spaces or control characters."
        )
    return stripped


def _load_dotenv(filepath: Path) -> Dict[str, str]:
    """
    Load key=value pairs from a .env file.

    Args:
        filepath: Path to the .env file.

    Returns:
        Dictionary of environment variables.

    Raises:
        EnvFileNotFoundError: If the file is missing.
        EnvError: If the file cannot be parsed.
    """
    if not filepath.is_file():
        raise EnvFileNotFoundError(
            f"Environment file not found at: {filepath}. "
            f"Create it by copying {EXAMPLE_FILE}."
        )

    env_vars: Dict[str, str] = {}
    try:
        with filepath.open("r", encoding="utf-8") as f:
            for line_no, line in enumerate(f, start=1):
                stripped = line.strip()
                if not stripped or stripped.startswith("#"):
                    continue
                if "=" not in stripped:
                    LOGGER.warning("Line %d: no '=' found – skipping", line_no)
                    continue
                key, _, value = stripped.partition("=")
                key = key.strip()
                if not key:
                    LOGGER.warning("Line %d: empty key – skipping", line_no)
                    continue
                env_vars[key] = value.strip()
    except OSError as exc:
        raise EnvError(f"Cannot read {filepath}: {exc}") from exc

    return env_vars

# ---------------------------------------------------------------------------
# Main loader
# ---------------------------------------------------------------------------


def load_environment(
    filepath: Optional[Path] = None,
    *,
    strict: bool = True,
    logger: Optional[logging.Logger] = None,
) -> Dict[str, str]:
    """
    Load and validate environment configuration.

    Reads a .env file, validates required keys, and returns a dictionary
    of all variables. Falls back to `os.environ` for any missing keys if
    `strict=False`. Logs warnings for unknown variables.

    Args:
        filepath: Path to .env file. If None, defaults to `Path('.env')` in
                  the current working directory.
        strict: If True, raises `MissingKeyError` when a required key is
                missing from both file and environment. If False, missing
                keys are logged as warnings and omitted from the result.
        logger: Optional logger instance; defaults to module logger.

    Returns:
        Dictionary of validated environment variables.

    Raises:
        EnvFileNotFoundError: If the .env file is missing.
        MissingKeyError: If strict mode and a required key is absent.
        InvalidKeyFormatError: If any key value fails validation.
        EnvError: On I/O or parsing failures.

    Example:
        >>> config = load_environment(Path("prod.env"))
        >>> print(config["NVIDIA_API_KEY"])
    """
    if logger is None:
        logger = LOGGER
    if filepath is None:
        filepath = Path(".env")

    logger.info("Loading environment from: %s", filepath.resolve())

    # Load from file
    file_vars = _load_dotenv(filepath)

    # Merge with system environment (file overrides)
    combined: Dict[str, str] = dict(os.environ)
    combined.update(file_vars)

    # Validate required keys
    validated: Dict[str, str] = {}
    for key in REQUIRED_KEYS:
        if key not in combined:
            if strict:
                raise MissingKeyError(
                    f"Required environment variable '{key}' is missing. "
                    f"Define it in your .env file or export it."
                )
            else:
                logger.warning("Required variable '%s' not found – skipping", key)
                continue
        value = combined[key]
        validated_value = _validate_api_key(value, key)
        validated[key] = validated_value

    # Log success
    logger.info(
        "Environment loaded: %d required keys (%d optional/skipped)",
        len(validated),
        len(combined) - len(validated),
    )

    # Return all loaded variables (including non‑required)
    return {**combined, **validated}

# ---------------------------------------------------------------------------
# Convenience function for quick access
# ---------------------------------------------------------------------------


def get_api_key(name: str, *, strict: bool = True) -> str:
    """
    Quickly retrieve a single API key from the environment.

    Args:
        name: Variable name (e.g., 'NVIDIA_API_KEY').
        strict: If True, raises on missing/invalid key.

    Returns:
        The validated API key string.

    Raises:
        MissingKeyError, InvalidKeyFormatError: As appropriate.
    """
    value = os.environ.get(name)
    if value is None:
        if strict:
            raise MissingKeyError(f"Environment variable '{name}' not found.")
        return ""
    return _validate_api_key(value, name)

